<%= form_with model: @post do |f| %>
  <% if @post.errors.any? %>
    <div class="errors">
      <% @post.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :body %>
    <%= f.text_area :body %>
  </div>

  <div>
    <%= f.label :excerpt %>
    <%= f.text_area :excerpt %>
  </div>

  <div>
    <%= f.label :published, "Publish now?" %>
    <%= f.check_box :published %>
  </div>

  <%= f.submit %>
<% end %>
